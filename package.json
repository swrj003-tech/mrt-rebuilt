    "preview": "vite preview",
    "start": "node server/index.js",
    "postinstall": "echo 'System Ready'"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "gsap": "^3.12.5",
    "postcss": "^8.4.47",
