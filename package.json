    "vite": "^8.0.10"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lenis": "^1.1.14",
    "multer": "^2.0.2",
    "mysql2": "^3.11.3",
    "node-cache": "^5.1.2",
    "sharp": "^0.33.5"
