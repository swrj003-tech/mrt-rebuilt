{
  "name": "mrt-rebuilt",
  "version": "1.0.10",
  "description": "MRT International Modern Rebuild with High-Res Visuals and robust error handling.",
  "type": "module",
  "main": "server/index.js",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
